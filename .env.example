# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_URL=jdbc:mysql://localhost:3306/cosmetic_db?useSSL=true&requireSSL=true
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_or_empty

# ========================================
# JWT SECURITY
# ========================================
# CRITICAL: Generate a strong random secret (256+ bits)
# Example generation: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS_LONG_USE_OPENSSL_RAND_BASE64_64

# ========================================
# CLOUDFLARE R2 STORAGE
# ========================================
R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-bucket-url.r2.dev
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key

# ========================================
# CORS CONFIGURATION
# ========================================
# Comma-separated list of allowed origins (no spaces)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=8080

# ========================================
# API DOCUMENTATION (Swagger)
# ========================================
# Set to true only in development/staging, false in production
SWAGGER_ENABLED=false

# ========================================
# FIREBASE CONFIGURATION (Optional)
# ========================================
# If using Firebase, place your firebase-adminsdk-xxx.json file in src/main/resources/
# and reference it in FirebaseConfig.java
